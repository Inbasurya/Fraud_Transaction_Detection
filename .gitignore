*.dll
*.dylib
*.so
*.lib

# SQLite databases & WAL files
*.sqlite
*.sqlite-shm
*.sqlite-wal
*.db

# Jupyter notebooks checkpoints
.ipynb_checkpoints/

# Environment variables
.env
.env.*
!.env.example

# Logs
*.log
logs/

# OS files
.DS_Store
Thumbs.db

