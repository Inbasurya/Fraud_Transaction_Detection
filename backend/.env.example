# Copy this to .env and fill in real values
# NEVER commit .env — only .env.example is safe to commit

# ── Database (Render provides this automatically) ──────────────
DATABASE_URL=postgresql://user:pass@host/dbname

# ── Redis (Render provides this automatically) ─────────────────
REDIS_URL=redis://localhost:6379

# ── Security ───────────────────────────────────────────────────
SECRET_KEY=generate-a-random-64-char-string-here

# ── Twilio SMS Alerts ──────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
ALERT_TO_NUMBER=+91xxxxxxxxxx

# ── CORS (comma-separated, no spaces) ─────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.onrender.com

# ── Environment ────────────────────────────────────────────────
ENVIRONMENT=production
APP_ENV=production
DEBUG=false
