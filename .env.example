# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/frauddb
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/frauddb
POSTGRES_URI=postgresql://postgres:postgres@localhost:5432/frauddb

# Redis
REDIS_URL=redis://localhost:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# Application
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=dev-secret-change-in-production

# ML Model
MODEL_LOCAL_PATH=models/fraud_model.pkl

# Twilio (optional)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_number

# SendGrid (optional)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@fraudsoc.ai
